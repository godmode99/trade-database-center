generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IngestionSource {
  FRED
  CALENDAR
  MT5
  CME_FEDWATCH
}

enum RunMode {
  DAILY
  WEEKLY
  MONTHLY
  INTRADAY
}

enum RunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum TriggerType {
  SCHEDULE
  MANUAL
  BACKFILL
}

enum Mt5Timeframe {
  M15
  H4
  D1
  W1
  MN1
}

enum FedwatchInstrument {
  SOFR
  ZQ
}

model IngestionRun {
  id              String          @id @default(uuid()) @db.Uuid
  source          IngestionSource
  mode            RunMode
  startedAt       DateTime        @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime?       @map("finished_at") @db.Timestamptz(6)
  status          RunStatus
  triggerType     TriggerType     @map("trigger_type")
  notes           String?
  manifestPayload Json?           @map("manifest_payload") @db.JsonB
  rowsExtracted   Int?            @map("rows_extracted")
  rowsInserted    Int?            @map("rows_inserted")
  rowsUpdated     Int?            @map("rows_updated")
  rowsRejected    Int?            @map("rows_rejected")
  staleSources    Json?           @map("stale_sources") @db.JsonB
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  fredObservations       FredObservation[]
  calendarEvents         CalendarEvent[]
  mt5Ohlcvs              Mt5Ohlcv[]
  mt5Features            Mt5Feature[]
  mt5Summaries           Mt5Summary[]
  fedwatchProbabilities  FedwatchProbability[]
  fedwatchQuotes         FedwatchQuote[]

  @@index([source, mode, startedAt(sort: Desc)], map: "idx_ingestion_runs_source_mode_started_at")
  @@index([status, startedAt(sort: Desc)], map: "idx_ingestion_runs_status_started_at")
  @@map("ingestion_runs")
}

model FredSeries {
  id           String            @id @default(uuid()) @db.Uuid
  seriesCode   String            @unique(map: "uq_fred_series_series_code") @map("series_code")
  title        String?
  frequency    String?
  unit         String?
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  observations FredObservation[]

  @@map("fred_series")
}

model FredObservation {
  id               BigInt        @id @default(autoincrement())
  seriesId         String        @map("series_id") @db.Uuid
  observationDate  DateTime      @map("observation_date") @db.Date
  valueNum         Decimal?      @map("value_num") @db.Decimal(18, 6)
  valueRaw         String?       @map("value_raw")
  mode             RunMode
  ingestionRunId   String        @map("ingestion_run_id") @db.Uuid
  sourceFile       String?       @map("source_file")
  sourceRecordHash String?       @map("source_record_hash")
  isDeleted        Boolean       @default(false) @map("is_deleted")
  sourceTimeLabel  String?       @map("source_time_label")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  series           FredSeries    @relation(fields: [seriesId], references: [id], onDelete: Restrict)
  ingestionRun     IngestionRun  @relation(fields: [ingestionRunId], references: [id], onDelete: Restrict)

  @@unique([seriesId, observationDate, mode], map: "uq_fred_observations_series_date_mode")
  @@index([seriesId, observationDate(sort: Desc)], map: "idx_fred_observations_series_date")
  @@index([mode, observationDate(sort: Desc)], map: "idx_fred_observations_mode_date")
  @@map("fred_observations")
}

model CalendarEvent {
  id               BigInt        @id @default(autoincrement())
  eventId          String        @map("event_id")
  eventDatetimeBkk DateTime      @map("event_datetime_bkk") @db.Timestamptz(6)
  datelineEpoch    BigInt?       @map("dateline_epoch")
  dayLabel         String?       @map("day_label")
  currency         String?
  country          String?
  impact           String?
  impactScore      Int?          @map("impact_score")
  timeLabel        String?       @map("time_label")
  name             String
  prefixedName     String?       @map("prefixed_name")
  actual           String?
  forecast         String?
  previous         String?
  revision         String?
  url              String?
  soloUrl          String?       @map("solo_url")
  isSelected       Boolean       @default(false) @map("is_selected")
  ingestionRunId   String        @map("ingestion_run_id") @db.Uuid
  sourceRecordHash String?       @map("source_record_hash")
  isDeleted        Boolean       @default(false) @map("is_deleted")
  sourceTimeLabel  String?       @map("source_time_label")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  ingestionRun     IngestionRun  @relation(fields: [ingestionRunId], references: [id], onDelete: Restrict)

  @@unique([eventId, eventDatetimeBkk], map: "uq_calendar_events_event_id_event_datetime")
  @@index([eventDatetimeBkk(sort: Desc)], map: "idx_calendar_events_event_datetime")
  @@index([currency, eventDatetimeBkk(sort: Desc)], map: "idx_calendar_events_currency_datetime")
  @@index([impactScore(sort: Desc), eventDatetimeBkk(sort: Desc)], map: "idx_calendar_events_impact_datetime")
  @@map("calendar_events")
}

model Mt5Symbol {
  id          String       @id @default(uuid()) @db.Uuid
  symbol      String       @unique(map: "uq_mt5_symbols_symbol")
  description String?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  ohlcv       Mt5Ohlcv[]
  features    Mt5Feature[]
  summaries   Mt5Summary[]

  @@map("mt5_symbols")
}

model Mt5Ohlcv {
  id               BigInt        @id @default(autoincrement())
  symbolId         String        @map("symbol_id") @db.Uuid
  timeframe        Mt5Timeframe
  candleTimeBkk    DateTime      @map("candle_time_bkk") @db.Timestamptz(6)
  open             Decimal       @db.Decimal(18, 6)
  high             Decimal       @db.Decimal(18, 6)
  low              Decimal       @db.Decimal(18, 6)
  close            Decimal       @db.Decimal(18, 6)
  tickVolume       BigInt        @map("tick_volume")
  ingestionRunId   String        @map("ingestion_run_id") @db.Uuid
  sourceRecordHash String?       @map("source_record_hash")
  isDeleted        Boolean       @default(false) @map("is_deleted")
  sourceTimeLabel  String?       @map("source_time_label")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  symbol           Mt5Symbol     @relation(fields: [symbolId], references: [id], onDelete: Restrict)
  ingestionRun     IngestionRun  @relation(fields: [ingestionRunId], references: [id], onDelete: Restrict)

  @@unique([symbolId, timeframe, candleTimeBkk], map: "uq_mt5_ohlcv_symbol_tf_candle")
  @@index([symbolId, timeframe, candleTimeBkk(sort: Desc)], map: "idx_mt5_ohlcv_symbol_tf_candle")
  @@map("mt5_ohlcv")
}

model Mt5Feature {
  id               BigInt        @id @default(autoincrement())
  symbolId         String        @map("symbol_id") @db.Uuid
  timeframe        Mt5Timeframe
  candleTimeBkk    DateTime      @map("candle_time_bkk") @db.Timestamptz(6)
  tr               Decimal?      @db.Decimal(18, 6)
  atr14            Decimal?      @db.Decimal(18, 6)
  range            Decimal?      @db.Decimal(18, 6)
  body             Decimal?      @db.Decimal(18, 6)
  upperWick        Decimal?      @map("upper_wick") @db.Decimal(18, 6)
  lowerWick        Decimal?      @map("lower_wick") @db.Decimal(18, 6)
  closePos         Decimal?      @map("close_pos") @db.Decimal(18, 6)
  swingHigh        Boolean?      @map("swing_high")
  swingLow         Boolean?      @map("swing_low")
  structureEvent   String?       @map("structure_event")
  bosUp            Int?          @map("bos_up")
  bosDn            Int?          @map("bos_dn")
  chochUp          Int?          @map("choch_up")
  chochDn          Int?          @map("choch_dn")
  ema20            Decimal?      @db.Decimal(18, 6)
  ema50            Decimal?      @db.Decimal(18, 6)
  prevHigh         Decimal?      @map("prev_high") @db.Decimal(18, 6)
  prevLow          Decimal?      @map("prev_low") @db.Decimal(18, 6)
  prevClose        Decimal?      @map("prev_close") @db.Decimal(18, 6)
  sweepPrevHigh    Int?          @map("sweep_prev_high")
  sweepPrevLow     Int?          @map("sweep_prev_low")
  ingestionRunId   String        @map("ingestion_run_id") @db.Uuid
  sourceRecordHash String?       @map("source_record_hash")
  isDeleted        Boolean       @default(false) @map("is_deleted")
  sourceTimeLabel  String?       @map("source_time_label")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  symbol           Mt5Symbol     @relation(fields: [symbolId], references: [id], onDelete: Restrict)
  ingestionRun     IngestionRun  @relation(fields: [ingestionRunId], references: [id], onDelete: Restrict)

  @@unique([symbolId, timeframe, candleTimeBkk], map: "uq_mt5_features_symbol_tf_candle")
  @@map("mt5_features")
}

model Mt5Summary {
  id               BigInt        @id @default(autoincrement())
  symbolId         String        @map("symbol_id") @db.Uuid
  mode             RunMode
  asof             DateTime      @db.Timestamptz(6)
  summaryPayload   Json          @map("summary_payload") @db.JsonB
  ingestionRunId   String        @map("ingestion_run_id") @db.Uuid
  sourceRecordHash String?       @map("source_record_hash")
  isDeleted        Boolean       @default(false) @map("is_deleted")
  sourceTimeLabel  String?       @map("source_time_label")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  symbol           Mt5Symbol     @relation(fields: [symbolId], references: [id], onDelete: Restrict)
  ingestionRun     IngestionRun  @relation(fields: [ingestionRunId], references: [id], onDelete: Restrict)

  @@index([symbolId, mode, asof(sort: Desc)], map: "idx_mt5_summaries_symbol_mode_asof")
  @@map("mt5_summaries")
}

model FedwatchProbability {
  id               BigInt             @id @default(autoincrement())
  instrument       FedwatchInstrument
  tableName        String             @map("table_name")
  symbol           String
  contractMonth    String             @map("contract_month")
  prediction       Decimal?           @db.Decimal(8, 4)
  current          Decimal?           @db.Decimal(8, 4)
  diff             Decimal?           @db.Decimal(8, 4)
  asofAt           DateTime           @map("asof_at") @db.Timestamptz(6)
  sourceFile       String?            @map("source_file")
  ingestionRunId   String             @map("ingestion_run_id") @db.Uuid
  sourceRecordHash String?            @map("source_record_hash")
  isDeleted        Boolean            @default(false) @map("is_deleted")
  sourceTimeLabel  String?            @map("source_time_label")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  ingestionRun     IngestionRun       @relation(fields: [ingestionRunId], references: [id], onDelete: Restrict)

  @@unique([instrument, tableName, symbol, contractMonth, asofAt], map: "uq_fedwatch_probabilities_nk")
  @@map("fedwatch_probabilities")
}

model FedwatchQuote {
  id               BigInt        @id @default(autoincrement())
  symbol           String
  displayName      String?       @map("display_name")
  mode             RunMode
  quoteDate        DateTime?     @map("quote_date") @db.Date
  expiryLabel      String?       @map("expiry_label")
  lastPrice        Decimal?      @map("last_price") @db.Decimal(18, 6)
  change           Decimal?      @db.Decimal(18, 6)
  open             Decimal?      @db.Decimal(18, 6)
  high             Decimal?      @db.Decimal(18, 6)
  low              Decimal?      @db.Decimal(18, 6)
  volume           BigInt?
  frontMonth       String?       @map("front_month")
  capturedAt       DateTime      @map("captured_at") @db.Timestamptz(6)
  sourceFile       String?       @map("source_file")
  ingestionRunId   String        @map("ingestion_run_id") @db.Uuid
  sourceRecordHash String?       @map("source_record_hash")
  isDeleted        Boolean       @default(false) @map("is_deleted")
  sourceTimeLabel  String?       @map("source_time_label")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  ingestionRun     IngestionRun  @relation(fields: [ingestionRunId], references: [id], onDelete: Restrict)

  @@unique([symbol, mode, capturedAt], map: "uq_fedwatch_quotes_symbol_mode_captured")
  @@map("fedwatch_quotes")
}
